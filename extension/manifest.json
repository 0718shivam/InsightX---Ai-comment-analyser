{
  "manifest_version": 3,
  "name": "InsightX",
  "version": "1.0",
  "description": "AI-Powered Real-Time YouTube Comment & Creator Analytics Platform",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "InsightX API-Powered Analytics"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/watch*"],
      "js": ["content.js"]
    }
  ]
}
